{
    "name": "moddev-branding-site",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "concurrently \"vite --host\" \"cd ./service && npm run dev\"",
        "build": "tsc -b && vite build && cd ./service && npm run build",
        "lint": "eslint .",
        "preview": "vite preview",
        "start": "npm run build && cd ./build && service.exe",
        "production": "npm run build && cd ./build && ./service"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^9.0.0",
        "@mui/material": "^9.0.0",
        "@mui/system": "^9.0.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-icons": "^5.6.0",
        "react-router-dom": "^7.14.2",
        "vite-plugin-babel": "^1.6.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "babel-plugin-react-compiler": "^1.0.0",
        "concurrently": "^9.2.1",
        "eslint": "^10.2.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.59.1",
        "vite": "^8.0.10"
    }
}
